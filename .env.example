# ─── Auth.js ───────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# ─── Google OAuth (primary sign-in) ────────────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
# Authorised JavaScript origins (include every host you deploy to):
#   http://localhost:3000
#   https://kitfolk.com
#   https://app.kitfolk.com
#   https://kitfolk.vercel.app   …and any *.vercel.app preview URL you use
# Authorised redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://kitfolk.com/api/auth/callback/google
#   https://app.kitfolk.com/api/auth/callback/google
#   https://kitfolk.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Auth.js URL (set on Vercel if OAuth callbacks use the wrong host) ────
# One canonical origin per deployment, e.g.
#   AUTH_URL=https://app.kitfolk.com
#   AUTH_URL=https://kitfolk.vercel.app
