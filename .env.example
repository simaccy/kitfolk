# ─── Auth.js ───────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# ─── Google OAuth (primary sign-in) ────────────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
# Authorised JavaScript origins:
#   http://localhost:3000
#   https://kitfolk.com
#   https://app.kitfolk.com
# Authorised redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://kitfolk.com/api/auth/callback/google
#   https://app.kitfolk.com/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Auth.js URL (production only, optional in dev) ────────────────────────
# AUTH_URL=https://app.kitfolk.com
